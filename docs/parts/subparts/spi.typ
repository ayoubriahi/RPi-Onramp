#hl[SPI Clock Modes (CPOL & CPHA)]

Two parameters control timing. Each has 2 options → *4 modes* total.

#v(0.4em)
#grid(
  columns: (1fr, 1fr),
  gutter: 1em,
  rect(fill: accent.lighten(85%), stroke: accent, radius: 6pt, inset: 11pt)[
    #text(weight: "bold", fill: accent)[CPOL — Clock Polarity] \
    #v(0.2em)
    #text(size: 16pt)[
      *CPOL=0* → clock idles *Low* \
      *CPOL=1* → clock idles *High*
    ]
  ],
  rect(fill: accent.lighten(85%), stroke: accent, radius: 6pt, inset: 11pt)[
    #text(weight: "bold", fill: accent)[CPHA — Clock Phase] \
    #v(0.2em)
    #text(size: 16pt)[
      *CPHA=0* → data sampled on *leading* edge \
      *CPHA=1* → data sampled on *trailing* edge
    ]
  ],
)

